# PostgreSQL connection string.
# Neon (recommended for newcomers): copy the "Pooled connection" string from neon.tech.
# Supabase: Project Settings → Database → Connection string (URI mode).
# Local Postgres: postgres://USER:PASSWORD@localhost:5432/DATABASE
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32   (or any 32+ char random string)
NEXTAUTH_SECRET="change-me-replace-with-a-long-random-string"
