// Yeild — Diamond Industry Suite
// SQLite for local-only deployment. Module boundaries are kept explicit
// so each could later be split into its own microservice.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Identity & access
// ─────────────────────────────────────────────────────────────
//
// Role values (SQLite has no enum support — enforced in code via src/lib/constants.ts):
//   ADMIN | OWNER | PLANNER | SUPERVISOR | WORKER | DEALER | VIEWER

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("VIEWER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workerProfile      Worker?
  cutPlansCreated    CutPlan[]      @relation("PlannerCutPlans")
  qualityChecks      QualityCheck[]
  listings           MarketplaceListing[]
  stageEvents        StageEvent[]
}

// ─────────────────────────────────────────────────────────────
// Module 1 — Yield Optimizer (rough planning)
// ─────────────────────────────────────────────────────────────

model RoughStone {
  id           String   @id @default(cuid())
  code         String   @unique
  weightCt     Float
  color        String?
  clarity      String?
  shape        String?
  scanData     String?  // JSON blob (Sarine-style data)
  costPerCt    Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())

  cutPlans     CutPlan[]
  stone        Stone?
}

model CutPlan {
  id              String   @id @default(cuid())
  roughStone      RoughStone @relation(fields: [roughStoneId], references: [id], onDelete: Cascade)
  roughStoneId    String
  name            String
  strategy        String   // "single-large" | "two-stones" | "yield-max" | custom
  expectedYieldPct Float
  estProfit       Float
  estRevenue      Float
  estCost         Float
  notes           String?
  isSelected      Boolean  @default(false)
  createdBy       User     @relation("PlannerCutPlans", fields: [createdById], references: [id])
  createdById     String
  createdAt       DateTime @default(now())

  outputs         PolishedOutput[]
}

model PolishedOutput {
  id          String   @id @default(cuid())
  plan        CutPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId      String
  weightCt    Float
  shape       String
  color       String
  clarity     String
  estPricePerCt Float
}

// ─────────────────────────────────────────────────────────────
// Module 2 — Manufacturing ERP (stone tracking)
// ─────────────────────────────────────────────────────────────
//
// Stage values (enforced in code):
//   PLANNING | SAWING | BRUTING | POLISHING | QC | CERTIFICATION | COMPLETED

model Stone {
  id            String   @id @default(cuid())
  qrCode        String   @unique
  roughStone    RoughStone? @relation(fields: [roughStoneId], references: [id])
  roughStoneId  String?  @unique
  currentStage  String   @default("PLANNING")
  startWeightCt Float
  currentWeightCt Float
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  events        StageEvent[]
  qualityChecks QualityCheck[]
  inventory     InventoryItem?
  traceEvents   TraceEvent[]
  jobOrderItems JobOrderItem[]
}

model StageEvent {
  id           String   @id @default(cuid())
  stone        Stone    @relation(fields: [stoneId], references: [id], onDelete: Cascade)
  stoneId      String
  stage        String
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  weightBefore Float
  weightAfter  Float?
  lossCt       Float?
  worker       User?    @relation(fields: [workerId], references: [id])
  workerId     String?
  notes        String?
}

// ─────────────────────────────────────────────────────────────
// Module 3 — Worker Productivity
// ─────────────────────────────────────────────────────────────

model Worker {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String   @unique
  employeeCode  String   @unique
  department    String   // SAWING / BRUTING / POLISHING / QC
  joinDate      DateTime @default(now())
  hourlyRate    Float    @default(0)

  dailyLogs     WorkerDailyLog[]
  incentives    Incentive[]
}

model WorkerDailyLog {
  id              String   @id @default(cuid())
  worker          Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId        String
  date            DateTime
  piecesCompleted Int      @default(0)
  recoveryPct     Float    @default(0)
  errors          Int      @default(0)
  machineHours    Float    @default(0)
  notes           String?

  @@unique([workerId, date])
}

model Incentive {
  id          String   @id @default(cuid())
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId    String
  monthYear   String   // "2026-05"
  amount      Float
  basis       String
  paid        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([workerId, monthYear])
}

// ─────────────────────────────────────────────────────────────
// Module 4 — Inventory + Marketplace
// ─────────────────────────────────────────────────────────────

model InventoryItem {
  id            String   @id @default(cuid())
  sku           String   @unique
  stone         Stone?   @relation(fields: [stoneId], references: [id])
  stoneId       String?  @unique
  shape         String
  caratWeight   Float
  color         String
  clarity       String
  cut           String?
  polish        String?
  symmetry      String?
  fluorescence  String?
  certificateNo String?
  certBody      String?  // GIA / IGI / HRD
  imageUrl      String?
  videoUrl      String?
  pricePerCt    Float
  totalPrice    Float
  status        String   @default("IN_STOCK") // IN_STOCK | RESERVED | SOLD | LISTED
  location      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listing       MarketplaceListing?
}

model MarketplaceListing {
  id          String   @id @default(cuid())
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String   @unique
  seller      User     @relation(fields: [sellerId], references: [id])
  sellerId    String
  listPrice   Float
  isPublic    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())

  inquiries   Inquiry[]
}

model Inquiry {
  id           String   @id @default(cuid())
  listing      MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId    String
  buyerName    String
  buyerEmail   String
  buyerPhone   String?
  message      String?
  status       String   @default("OPEN") // OPEN | RESPONDED | CLOSED
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Module 5 — Price Intelligence
// ─────────────────────────────────────────────────────────────

model PricePoint {
  id            String   @id @default(cuid())
  shape         String
  caratBucket   String   // "1.00-1.49" etc.
  color         String
  clarity       String
  source        String   // RAPAPORT / IDEX / MANUAL
  pricePerCt    Float
  recordedAt    DateTime @default(now())

  @@index([shape, color, clarity, caratBucket, recordedAt])
}

// ─────────────────────────────────────────────────────────────
// Module 6 — Traceability (mine → jewelry)
// ─────────────────────────────────────────────────────────────

model TraceEvent {
  id           String   @id @default(cuid())
  stone        Stone    @relation(fields: [stoneId], references: [id], onDelete: Cascade)
  stoneId      String
  eventType    String   // MINED / RECEIVED / PLANNED / SAWED / POLISHED / CERTIFIED / SOLD / SHIPPED
  actor        String   // entity that performed event
  location     String?
  metadata     String?  // JSON
  recordedAt   DateTime @default(now())
  prevHash     String?
  hash         String

  @@index([stoneId, recordedAt])
}

// ─────────────────────────────────────────────────────────────
// Module 7 — Quality Defect Detection
// ─────────────────────────────────────────────────────────────

model QualityCheck {
  id           String   @id @default(cuid())
  stone        Stone    @relation(fields: [stoneId], references: [id], onDelete: Cascade)
  stoneId      String
  inspector    User     @relation(fields: [inspectorId], references: [id])
  inspectorId  String
  imageUrl     String?
  defectsFound String?  // JSON array
  defectCount  Int      @default(0)
  overallScore Float    // 0-100
  recommendation String  // PASS | REWORK | REJECT
  notes        String?
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Module 8 — Job Work / Outsourcing
// ─────────────────────────────────────────────────────────────

model Vendor {
  id          String   @id @default(cuid())
  name        String   @unique
  contact     String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now())

  jobOrders   JobOrder[]
}

model JobOrder {
  id            String   @id @default(cuid())
  orderCode     String   @unique
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  vendorId      String
  jobType       String   // SAWING / POLISHING / BRUTING / QC
  sentAt        DateTime @default(now())
  expectedAt    DateTime?
  returnedAt    DateTime?
  totalSentCt   Float    @default(0)
  totalReturnCt Float    @default(0)
  lossCt        Float    @default(0)
  ratePerCt     Float    @default(0)
  totalPayment  Float    @default(0)
  paid          Boolean  @default(false)
  status        String   @default("SENT") // SENT | IN_PROGRESS | RETURNED | CLOSED
  notes         String?

  items         JobOrderItem[]
}

model JobOrderItem {
  id           String   @id @default(cuid())
  order        JobOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  stone        Stone    @relation(fields: [stoneId], references: [id])
  stoneId      String
  sentWeightCt Float
  returnWeightCt Float?
}
